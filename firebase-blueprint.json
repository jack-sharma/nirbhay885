{
  "entities": {
    "userProfile": {
      "title": "User Profile",
      "description": "Stores user preferences and basic information for personalization.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "preferences": { "type": "object" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["uid"]
    },
    "conversation": {
      "title": "Conversation History",
      "description": "Stores past conversation snippets for context and memory.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "summary": { "type": "string" },
        "emotion": { "type": "string" }
      },
      "required": ["userId", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "userProfile",
      "description": "User profile data."
    },
    "/users/{userId}/history/{convId}": {
      "schema": "conversation",
      "description": "User's conversation history."
    }
  }
}
